# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=bot_token

# OpenAI API key (for Whisper + Chat Completions)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override temp directory (default: /tmp/recipemart or ./tmp)
# TMPDIR=/tmp

# Optional: Instagram cookies to avoid "login required" / rate-limit.
# - Local: path to a Netscape-format cookies file, e.g. INSTAGRAM_COOKIES=/path/to/cookies.txt
# - Railway/cloud: export cookies to cookies.txt, then base64 -i cookies.txt and paste the result here as INSTAGRAM_COOKIES
INSTAGRAM_COOKIES=./cookies.txt

# Optional: recipe model (default gpt-4o-mini)
# OPENAI_RECIPE_MODEL=gpt-4o-mini

# Optional: pipeline limits
# STT_MAX_DURATION_SECONDS=600
# OCR_FRAME_INTERVAL_SECONDS=2.0
# OCR_MAX_FRAMES=60
